APP_ENV=local
WEB_PORT=8000
WEB_AUTH_DISABLED=false
AUTH_JWT_SECRET=
AUTH_TOKEN_TTL_MINUTES=480
AUTH_BOOTSTRAP_ADMIN_USERNAME=admin
# Minimum 12 characters. Used only to create the first admin user.
AUTH_BOOTSTRAP_ADMIN_PASSWORD=

# Legacy fallback only. Prefer AUTH_JWT_SECRET for new installs.
WEB_API_KEY=

PROJECTS_DIR=projects
DATA_DIR=data
LOGS_DIR=logs
DATABASE_URL=sqlite:///data/lastest.sqlite3

JOB_POLL_INTERVAL_SEC=2
COMMAND_TIMEOUT_SEC=3600
MAX_LOG_TAIL_BYTES=200000

CENSYS_PERSONAL_ACCESS_TOKEN=
FINDOMAIN_VIRUSTOTAL_TOKEN=
SHODAN_API_KEY=
